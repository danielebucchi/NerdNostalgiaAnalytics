# --- Main bot ---
TELEGRAM_BOT_TOKEN=your_main_bot_token

# DATABASE_URL: when running natively keep the relative path; in Docker compose
# overrides this to /app/data/ so SQLite lands inside the mounted volume.
DATABASE_URL=sqlite+aiosqlite:///./nerd_nostalgia.db

PRICECHARTING_API_TOKEN=

# eBay API (get from https://developer.ebay.com/my/keys)
EBAY_APP_ID=
EBAY_CERT_ID=

# CardTrader seller JWT (https://www.cardtrader.com app management)
CARDTRADER_TOKEN=

# Groq API key (optional) — enables LLM fallback for noisy queries.
# Genuine EEA-friendly free tier: 30 RPM / 6000 RPD on llama-3.3-70b-versatile.
# No billing required. Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# --- Lite bot (optional; only needed when running with --profile lite) ---
TELEGRAM_BOT_TOKEN_LITE=your_lite_bot_token
CHECK_INTERVAL_MINUTES=30
